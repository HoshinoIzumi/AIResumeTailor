# Copy to .env and fill in. Never commit .env.

# Base URL of your n8n instance (no trailing path). Used by Phase 2 Next.js proxy.
# Local Docker default: http://localhost:5678
N8N_BASE_URL=http://localhost:5678

# Full webhook URL for the analyze_jd workflow after import (production URL from n8n UI).
# Example: http://localhost:5678/webhook/analyze-jd
N8N_WEBHOOK_URL=http://localhost:5678/webhook/analyze-jd

# Shared secret: send Authorization: Bearer <token> from Next.js; same value in n8n env as N8N_WEBHOOK_SECRET.
N8N_WEBHOOK_SECRET=change-me-to-a-long-random-string

# OpenAI API key — set in n8n as an OpenAI credential on the four OpenAI nodes (not in Next.js for Phase 1–2).
